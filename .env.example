# 마케팅 에이전트 팀 환경 변수
# 이 파일을 복사해서 .env로 저장하고 실제 값을 입력하세요.
# .env 파일은 절대 커밋하거나 공유하지 마세요.

# Buffer API (소셜 미디어 예약 포스팅)
# 발급 방법: https://buffer.com/developers/api 접속 → Access the Beta → Generate Key
BUFFER_API_KEY=your_buffer_api_key_here

# Gemini API (고품질 이미지 생성 — 나노바나나 MCP 연동용)
# 발급: Google AI Studio → API Keys
GEMINI_API_KEY=your_gemini_api_key_here
